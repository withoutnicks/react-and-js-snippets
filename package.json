{
  "name": "wts-react-js-snippets",
  "displayName": "React, Typescript & Javascript Snippets",
  "description": "Curated snippets for React, TypeScript, and JavaScript with consistent naming, aliases, and modern React coverage.",
  "version": "1.4.0",
  "icon": "logo.png",
  "author": {
    "name": "withoutnicks"
  },
